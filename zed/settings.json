// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "tab_size": 2,
  "agent": {
    "default_model": {
      "provider": "ollama",
      "model": "qwen3:1.7b"
    },
    "model_parameters": []
  },
  "language_models": {
    "ollama": {
      "api_url": "http://localhost:11434",
      "available_models": [
        {
          "name": "qwen2.5-coder",
          "display_name": "qwen 2.5 coder 32K",
          "max_tokens": 32768,
          "supports_tools": true,
          "supports_thinking": true,
          "supports_images": true
        }
      ]
    }
  },
  "preferred_line_length": 140,
  "soft_wrap": "bounded",
  "features": {
    "edit_prediction_provider": "none"
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "vim_mode": true,
  "vim": {
    "cursor_shape": {
      "normal": "hollow",
      "replace": "underline",
      "visual": "block"
    }
  },
  "relative_line_numbers": "enabled",
  "ui_font_size": 13,
  "buffer_font_size": 12,
  "theme": "SynthWave 84 Dark",
  "experimental.theme_overrides": {
    "search.match_background": "#ff00f090",
    "warning.background": "#FF00FF20",
    // "hint.background": "#FF00FF20",
    // "error.background": "#FF00FF20",
    // "info.background": "#FF00FF20",
    "players": [
      {
        "selection": "#FF00FF20"
      }
    ]
  }
}
